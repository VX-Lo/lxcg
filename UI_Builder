    self.deIconPv = ef:CreateTexture(nil, "ARTWORK"); self.deIconPv:SetSize(24, 24)
    self.deIconPv:SetPoint("LEFT", il, "RIGHT", 8, 0); self.deIconPv:SetTexCoord(0.07, 0.93, 0.07, 0.93)
    local dbb = SmallBtn(ef, "Browse", 56, function()
        LXCG.IconPicker:Open(function(iconId, displayText)
            self.deIconField:SetText(displayText)
            self.deIconPv:SetTexture(LXCG:ResolveIcon(displayText))
        end)
