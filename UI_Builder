function LXCG.Builder:RefreshDecks()
    if not self.dSelArea then return end
    for _, b in ipairs(self.dSelBtns) do b:Hide() end
    local idx = 0
    for dId, deck in pairs(LXCG.Data.decks) do
        idx = idx + 1
        local btn = self.dSelBtns[idx]
        if not btn then
            btn = CreateFrame("Button", nil, self.dSelArea, "BackdropTemplate"); btn:SetSize(80, 20)
            btn:SetBackdrop({ bgFile="Interface\\Buttons\\WHITE8x8", edgeFile="Interface\\Buttons\\WHITE8x8", edgeSize=1 })
            btn._label = btn:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
            btn._label:SetAllPoints(); btn._label:SetJustifyH("CENTER")
            self.dSelBtns[idx] = btn
        end
        btn:SetPoint("TOPLEFT", (idx - 1) * 84, 0); btn._label:SetText(deck.name)
        local sel = (dId == selectedDeckId)
        btn:SetBackdropColor(sel and 0.2 or 0.12, sel and 0.2 or 0.12, sel and 0.3 or 0.15, 1)
        btn:SetBackdropBorderColor(sel and 0.5 or 0.3, sel and 0.5 or 0.3, sel and 0.7 or 0.3, 1)
        local cid = dId
        btn:SetScript("OnClick", function() selectedDeckId = cid; self:RefreshDecks() end)
        btn:Show()
    end
    self:RefreshDeckCards()
end

function LXCG.Builder:RefreshDeckCards()
    if not self.dContent then return end
    for _, b in ipairs(self.dCardBtns) do b:Hide() end
    if not selectedDeckId then return end
    local deck = LXCG.Data.decks[selectedDeckId]
    if not deck then return end
    local idx = 0
    for _, entry in ipairs(deck.cards) do
        idx = idx + 1
        local tmpl = LXCG.Data:GetTemplate(entry.templateId)
        local btn = self.dCardBtns[idx]
        if not btn then
            btn = CreateFrame("Button", nil, self.dContent); btn:SetSize(280, 22)
            btn:SetHighlightTexture("Interface\\Buttons\\WHITE8x8"); btn:GetHighlightTexture():SetVertexColor(1,1,1,0.08)
            btn._icon = btn:CreateTexture(nil, "ARTWORK"); btn._icon:SetSize(18, 18); btn._icon:SetPoint("LEFT", 2, 0)
            btn._icon:SetTexCoord(0.07, 0.93, 0.07, 0.93)
            btn._label = btn:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
            btn._label:SetPoint("LEFT", btn._icon, "RIGHT", 4, 0); btn._label:SetPoint("RIGHT", -42, 0); btn._label:SetJustifyH("LEFT")
            btn._minus = CreateFrame("Button", nil, btn); btn._minus:SetSize(18, 18); btn._minus:SetPoint("RIGHT", -18, 0)
            btn._minus:SetNormalFontObject("GameFontNormalSmall"); btn._minus:SetText("-")
            local mhl = btn._minus:CreateTexture(nil, "HIGHLIGHT"); mhl:SetAllPoints(); mhl:SetColorTexture(1, 0.3, 0.3, 0.2)
            btn._plus = CreateFrame("Button", nil, btn); btn._plus:SetSize(18, 18); btn._plus:SetPoint("RIGHT", 0, 0)
            btn._plus:SetNormalFontObject("GameFontNormalSmall"); btn._plus:SetText("+")
            local phl = btn._plus:CreateTexture(nil, "HIGHLIGHT"); phl:SetAllPoints(); phl:SetColorTexture(0.3, 1, 0.3, 0.2)
            self.dCardBtns[idx] = btn
        end
        btn:SetPoint("TOPLEFT", 0, -(idx - 1) * 22)
        btn._icon:SetTexture(tmpl and tmpl.icon or LXCG.CARD_BACK)
        btn._label:SetText((tmpl and tmpl.name or "?") .. "  |cffaaaaaa x" .. entry.count .. "|r")
        local ct = entry.templateId
        btn._minus:SetScript("OnClick", function() LXCG.Data:RemoveFromDeck(selectedDeckId, ct, 1) end)
        btn._plus:SetScript("OnClick", function() LXCG.Data:AddToDeck(selectedDeckId, ct, 1) end)
        btn:Show()
    end
    self.dContent:SetHeight(math.max(1, idx * 22))
end

