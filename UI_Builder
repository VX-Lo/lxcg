    self.deIconField = CreateFrame("EditBox", nil, ef, "InputBoxTemplate")
    self.deIconField:SetSize(90, 20); self.deIconField:SetPoint("LEFT", dbb, "RIGHT", 6, 0); self.deIconField:SetAutoFocus(false)
    self.deIconField:SetScript("OnTextChanged", function(eb)
        self.deIconPv:SetTexture(LXCG:ResolveIcon(eb:GetText()))
    end)

    local saveBtn = SmallBtn(ef, "Save", 60, function()
        if not self._editingDeckId then return end
        local name = self.deNameBox:GetText()
        local icon = self.deIconField:GetText()
