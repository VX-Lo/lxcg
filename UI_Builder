local allIconData, pickerState
local PCOLS, PROWS, PICON, PPAD = 8, 9, 32, 3

local function EnsureIconData()
    if allIconData then return end
    allIconData = {}
    for _, name in ipairs(CURATED_ICONS) do
        allIconData[#allIconData + 1] = { id = "Interface\\Icons\\" .. name, name = name }
    end
    local blizz = {}
    if type(GetMacroIcons) == "function" then GetMacroIcons(blizz) end
    if type(GetMacroItemIcons) == "function" then GetMacroItemIcons(blizz) end
    for _, fid in ipairs(blizz) do allIconData[#allIconData + 1] = { id = fid, name = nil } end
end

local function FilterIcons(query)
    local q = strlower(strtrim(query or ""))
    pickerState.filtered = {}
    for _, e in ipairs(allIconData) do
        if q == "" or (e.name and strlower(e.name):find(q, 1, true)) then
            pickerState.filtered[#pickerState.filtered + 1] = e
        end
    end
    pickerState.scrollOffset = 0
    if pickerState.slider then
        local maxS = math.max(0, math.ceil(#pickerState.filtered / PCOLS) - PROWS)
        pickerState.slider:SetMinMaxValues(0, maxS); pickerState.slider:SetValue(0)
    end
    if pickerState.countText then
        local s, t = #pickerState.filtered, #allIconData
        pickerState.countText:SetText("|cff888888" .. (s == t and (s .. " icons") or (s .. " of " .. t)) .. "|r")
    end
end

local function UpdatePickerGrid()
    local start = pickerState.scrollOffset * PCOLS + 1
    for i = 1, PCOLS * PROWS do
        local btn = pickerState.gridBtns[i]
        if not btn then break end
        local di = start + i - 1
        if di <= #pickerState.filtered then
            btn._tex:SetTexture(pickerState.filtered[di].id)
            btn._entry = pickerState.filtered[di]; btn:Show()
        else btn._entry = nil; btn:Hide() end
    end
end

local function BuildIconPickerFrame()
    local gW = PCOLS * (PICON + PPAD); local gH = PROWS * (PICON + PPAD)
    local pf = CreateFrame("Frame", "LXCGIconPicker", UIParent, "BackdropTemplate")
    pf:SetSize(gW + 52, gH + 80); pf:SetPoint("CENTER"); pf:SetFrameStrata("FULLSCREEN_DIALOG")
    pf:SetBackdrop({ bgFile="Interface\\Buttons\\WHITE8x8", edgeFile="Interface\\Buttons\\WHITE8x8", edgeSize=2 })
    pf:SetBackdropColor(0.08, 0.08, 0.1, 0.98); pf:SetBackdropBorderColor(0.5, 0.5, 0.5, 1)
    pf:EnableMouse(true); pf:Hide()
    pf:CreateFontString(nil, "OVERLAY", "GameFontNormal"):SetPoint("TOP", 0, -8)
    local cb = CreateFrame("Button", nil, pf, "UIPanelCloseButton"); cb:SetPoint("TOPRIGHT", -2, -2)
    cb:SetScript("OnClick", function() pf:Hide() end)
    local sb = CreateFrame("EditBox", nil, pf, "InputBoxTemplate")
    sb:SetSize(gW, 20); sb:SetPoint("TOPLEFT", 10, -28); sb:SetAutoFocus(false)
    pickerState.searchBox = sb
    local ph = sb:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
    ph:SetPoint("LEFT", 4, 0); ph:SetText("|cff666666Search or browse...|r")
    sb:SetScript("OnTextChanged", function(eb)
        ph:SetShown(eb:GetText() == ""); FilterIcons(eb:GetText()); UpdatePickerGrid()
    end)
    pickerState.countText = pf:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
    pickerState.countText:SetPoint("TOPLEFT", 10, -50)
    local ga = CreateFrame("Frame", nil, pf); ga:SetSize(gW, gH); ga:SetPoint("TOPLEFT", 10, -64)
    ga:EnableMouseWheel(true)
    for i = 1, PCOLS * PROWS do
        local r = math.floor((i - 1) / PCOLS); local c = (i - 1) % PCOLS
        local btn = CreateFrame("Button", nil, ga); btn:SetSize(PICON, PICON)
        btn:SetPoint("TOPLEFT", c * (PICON + PPAD), -r * (PICON + PPAD))
        local tex = btn:CreateTexture(nil, "ARTWORK"); tex:SetAllPoints(); tex:SetTexCoord(0.07, 0.93, 0.07, 0.93)
        btn._tex = tex
        local hl = btn:CreateTexture(nil, "HIGHLIGHT"); hl:SetAllPoints(); hl:SetColorTexture(1, 1, 1, 0.3)
        btn:SetScript("OnClick", function(self)
            if not self._entry or not pickerState.callback then return end
            local e = self._entry
            pickerState.callback(e.id, e.name or tostring(e.id)); pf:Hide()
        end)
        btn:SetScript("OnEnter", function(self)
            if not self._entry then return end
            GameTooltip:SetOwner(self, "ANCHOR_RIGHT")
            GameTooltip:AddLine(self._entry.name or ("Icon #" .. tostring(self._entry.id)), 1, 1, 1)
            GameTooltip:Show()
        end)
        btn:SetScript("OnLeave", function() GameTooltip:Hide() end)
        pickerState.gridBtns[i] = btn
    end
    local sl = CreateFrame("Slider", nil, pf); sl:SetSize(16, gH)
    sl:SetPoint("TOPLEFT", ga, "TOPRIGHT", 4, 0); sl:SetOrientation("VERTICAL")
    sl:SetMinMaxValues(0, 0); sl:SetValue(0); sl:SetValueStep(1); sl:SetObeyStepOnDrag(true); sl:EnableMouse(true)
    local slBg = sl:CreateTexture(nil, "BACKGROUND"); slBg:SetAllPoints(); slBg:SetColorTexture(0.12, 0.12, 0.15, 1)
    local th = sl:CreateTexture(nil, "OVERLAY"); th:SetSize(16, 24); th:SetColorTexture(0.4, 0.4, 0.5, 1)
    sl:SetThumbTexture(th)
    sl:SetScript("OnValueChanged", function(_, val)
        pickerState.scrollOffset = math.floor(val + 0.5); UpdatePickerGrid()
    end)
    pickerState.slider = sl
    ga:SetScript("OnMouseWheel", function(_, delta)
        local mn, mx = sl:GetMinMaxValues()
        sl:SetValue(math.max(mn, math.min(mx, sl:GetValue() - delta * 3)))
    end)
    pickerState.frame = pf
end

function LXCG.IconPicker:Open(callback)
    if not pickerState then
        pickerState = { filtered = {}, scrollOffset = 0, callback = nil, gridBtns = {}, frame = nil }
    end
    EnsureIconData()
    if not pickerState.frame then BuildIconPickerFrame() end
    pickerState.callback = callback
    pickerState.searchBox:SetText("")
    FilterIcons(""); UpdatePickerGrid()
    pickerState.frame:Show()
end

