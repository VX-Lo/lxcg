LXCG.Builder = {}
local builderFrame, selectedTemplateId, selectedDeckId, editingTemplateId

function LXCG.Builder:Toggle()
    if not builderFrame then self:Build() end
    if builderFrame:IsShown() then builderFrame:Hide()
    else builderFrame:Show(); self:RefreshTemplates(); self:RefreshDecks() end
end

local function SmallBtn(parent, text, width, onClick)
    local b = CreateFrame("Button", nil, parent, "BackdropTemplate")
    b:SetSize(width, 20)
    b:SetBackdrop({ bgFile="Interface\\Buttons\\WHITE8x8", edgeFile="Interface\\Buttons\\WHITE8x8", edgeSize=1 })
    b:SetBackdropColor(0.18, 0.18, 0.22, 1); b:SetBackdropBorderColor(0.4, 0.4, 0.4, 1)
    local l = b:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall"); l:SetAllPoints(); l:SetText(text)
    b:SetScript("OnClick", onClick)
    b:SetScript("OnEnter", function(s) s:SetBackdropColor(0.28, 0.28, 0.35, 1) end)
    b:SetScript("OnLeave", function(s) s:SetBackdropColor(0.18, 0.18, 0.22, 1) end)
    return b
end

function LXCG.Builder:Build()
    local f = CreateFrame("Frame", "LXCGBuilder", UIParent, "BackdropTemplate")
    f:SetSize(640, 480); f:SetPoint("CENTER")
    f:SetBackdrop({ bgFile="Interface\\Buttons\\WHITE8x8", edgeFile="Interface\\Buttons\\WHITE8x8", edgeSize=2 })
    f:SetBackdropColor(0.06, 0.06, 0.08, 0.98); f:SetBackdropBorderColor(0.3, 0.3, 0.3, 1)
    f:SetMovable(true); f:EnableMouse(true); f:RegisterForDrag("LeftButton"); f:SetClampedToScreen(true)
    f:SetScript("OnDragStart", f.StartMoving)
    f:SetScript("OnDragStop", function(self)
        self:StopMovingOrSizing()
        local l, b = self:GetLeft(), self:GetBottom()
        if l and b then LXCG.Storage:SetPref("builderX", l); LXCG.Storage:SetPref("builderY", b) end
    end)
    f:SetFrameStrata("HIGH"); f:Hide(); builderFrame = f
    local prefs = LXCG.Storage:GetPrefs()
    if prefs.builderX and prefs.builderY then
        f:ClearAllPoints(); f:SetPoint("BOTTOMLEFT", UIParent, "BOTTOMLEFT", prefs.builderX, prefs.builderY)
    end
    f:CreateFontString(nil, "OVERLAY", "GameFontNormal"):SetPoint("TOPLEFT", 10, -8)
    local closeBtn = CreateFrame("Button", nil, f, "UIPanelCloseButton"); closeBtn:SetPoint("TOPRIGHT", -2, -2)
    local div = f:CreateTexture(nil, "ARTWORK")
    div:SetPoint("TOP", f, "TOP", 0, -30); div:SetPoint("BOTTOM", f, "BOTTOM", 0, 8)
    div:SetWidth(1); div:SetColorTexture(0.3, 0.3, 0.3, 1)
    self:BuildTemplatePanel(f)
    self:BuildDeckPanel(f)
    self:BuildTemplateEditor(f)
    self:BuildDeckEditor(f)
    LXCG:On("TEMPLATES_CHANGED", function() LXCG.Builder:RefreshTemplates() end)
    LXCG:On("DECKS_CHANGED",    function() LXCG.Builder:RefreshDecks() end)
end

