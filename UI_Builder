    p:SetPoint("TOPLEFT", 8, -30); p:SetPoint("BOTTOMLEFT", 8, 8); p:SetWidth(306)
    self.tPanel = p
    p:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall"):SetPoint("TOPLEFT", 0, 0)
    local nb = SmallBtn(p, "New", 44, function() self:ShowEditor(nil) end); nb:SetPoint("TOPRIGHT", p, "TOPRIGHT", 0, 2)
    local eb = SmallBtn(p, "Edit", 44, function() if selectedTemplateId then self:ShowEditor(selectedTemplateId) end end)
    eb:SetPoint("RIGHT", nb, "LEFT", -4, 0)
    local db = SmallBtn(p, "Del", 36, function()
        if selectedTemplateId then LXCG.Data:DeleteTemplate(selectedTemplateId); selectedTemplateId = nil end
    end); db:SetPoint("RIGHT", eb, "LEFT", -4, 0)
    local sf = CreateFrame("ScrollFrame", nil, p, "UIPanelScrollFrameTemplate")
    sf:SetPoint("TOPLEFT", 0, -20); sf:SetPoint("BOTTOMRIGHT", -22, 38)
    local content = CreateFrame("Frame", nil, sf); content:SetWidth(280); content:SetHeight(1)
    sf:SetScrollChild(content); self.tContent = content; self.tBtns = {}
    -- Preview
    local pv = CreateFrame("Frame", nil, p); pv:SetPoint("BOTTOMLEFT"); pv:SetPoint("BOTTOMRIGHT"); pv:SetHeight(32)
    self.pvIcon = pv:CreateTexture(nil, "ARTWORK"); self.pvIcon:SetSize(24, 24)
    self.pvIcon:SetPoint("LEFT"); self.pvIcon:SetTexCoord(0.07, 0.93, 0.07, 0.93); self.pvIcon:SetTexture(LXCG.CARD_BACK)
    self.pvName = pv:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall"); self.pvName:SetPoint("LEFT", self.pvIcon, "RIGHT", 6, 0)
    local ab = SmallBtn(p, "Add to Deck", 90, function()
        if selectedTemplateId and selectedDeckId then LXCG.Data:AddToDeck(selectedDeckId, selectedTemplateId, 1) end
    end); ab:SetPoint("BOTTOMRIGHT", p, "BOTTOMRIGHT", 0, 4)
end

function LXCG.Builder:RefreshTemplates()
    if not self.tContent then return end
    for _, b in ipairs(self.tBtns) do b:Hide() end
    local idx = 0
    for tId, tmpl in pairs(LXCG.Data.templates) do
        idx = idx + 1
        local btn = self.tBtns[idx]
        if not btn then
            btn = CreateFrame("Button", nil, self.tContent); btn:SetSize(280, 22)
            btn:SetHighlightTexture("Interface\\Buttons\\WHITE8x8"); btn:GetHighlightTexture():SetVertexColor(1,1,1,0.08)
            btn._icon = btn:CreateTexture(nil, "ARTWORK"); btn._icon:SetSize(18, 18); btn._icon:SetPoint("LEFT", 2, 0)
            btn._icon:SetTexCoord(0.07, 0.93, 0.07, 0.93)
            btn._label = btn:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
            btn._label:SetPoint("LEFT", btn._icon, "RIGHT", 4, 0); btn._label:SetJustifyH("LEFT")
            btn._sel = btn:CreateTexture(nil, "BACKGROUND"); btn._sel:SetAllPoints(); btn._sel:SetColorTexture(0.2, 0.4, 0.6, 0.3)
            self.tBtns[idx] = btn
        end
        btn:SetPoint("TOPLEFT", 0, -(idx - 1) * 22)
        btn._icon:SetTexture(tmpl.icon); btn._label:SetText(tmpl.name)
        btn._sel:SetShown(tId == selectedTemplateId)
        local cid = tId
        btn:SetScript("OnClick", function() selectedTemplateId = cid; self:RefreshTemplates(); self:UpdatePreview() end)
        btn:Show()
    end
    self.tContent:SetHeight(math.max(1, idx * 22)); self:UpdatePreview()
end

function LXCG.Builder:UpdatePreview()
    if not selectedTemplateId then self.pvIcon:SetTexture(LXCG.CARD_BACK); self.pvName:SetText(""); return end
    local t = LXCG.Data:GetTemplate(selectedTemplateId)
    if t then self.pvIcon:SetTexture(t.icon)
        self.pvName:SetText(t.name .. (t.category ~= "" and ("  |cff888888" .. t.category .. "|r") or ""))
    end
end

