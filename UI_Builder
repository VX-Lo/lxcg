    self.edTitle:SetPoint("TOP", 0, -10)

    local function Row(lbl, yOff)
        local l = ef:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
        l:SetPoint("TOPLEFT", 12, yOff); l:SetWidth(64); l:SetJustifyH("RIGHT"); l:SetText(lbl)
        local eb = CreateFrame("EditBox", nil, ef, "InputBoxTemplate")
        eb:SetSize(190, 20); eb:SetPoint("LEFT", l, "RIGHT", 8, 0); eb:SetAutoFocus(false)
        return eb
    end

    self.edName = Row("Name:", -34)
    self.edCat = Row("Category:", -60)
    self.edText = Row("Text:", -86)

    -- Icon row
    local il = ef:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
    il:SetPoint("TOPLEFT", 12, -112); il:SetWidth(64); il:SetJustifyH("RIGHT"); il:SetText("Icon:")
    self.edIconPv = ef:CreateTexture(nil, "ARTWORK"); self.edIconPv:SetSize(28, 28)
    self.edIconPv:SetPoint("LEFT", il, "RIGHT", 8, 0); self.edIconPv:SetTexCoord(0.07, 0.93, 0.07, 0.93)
    self.edIconPv:SetTexture(LXCG.CARD_BACK)
    local bb = SmallBtn(ef, "Browse", 56, function()
        LXCG.IconPicker:Open(function(iconId, displayText)
            self.edIconField:SetText(displayText)
        end)
    end); bb:SetPoint("LEFT", self.edIconPv, "RIGHT", 6, 0)
    self.edIconField = CreateFrame("EditBox", nil, ef, "InputBoxTemplate")
    self.edIconField:SetSize(100, 20); self.edIconField:SetPoint("LEFT", bb, "RIGHT", 6, 0); self.edIconField:SetAutoFocus(false)
    self.edIconField:SetScript("OnTextChanged", function(eb)
        self.edIconPv:SetTexture(LXCG:ResolveIcon(eb:GetText()))
    end)

    -- Fields (3 fixed rows)
    local flbl = ef:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
    flbl:SetPoint("TOPLEFT", 12, -146); flbl:SetText("|cffaaaaaaFields (optional):|r")
    self.edFields = {}
    for i = 1, 3 do
        local y = -164 - (i - 1) * 24
        local nl = ef:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
        nl:SetPoint("TOPLEFT", 20, y); nl:SetWidth(50); nl:SetJustifyH("RIGHT")
        nl:SetText("|cff888888Name:|r")
        local ne = CreateFrame("EditBox", nil, ef, "InputBoxTemplate")
        ne:SetSize(80, 18); ne:SetPoint("LEFT", nl, "RIGHT", 4, 0); ne:SetAutoFocus(false)
        local vl = ef:CreateFontString(nil, "OVERLAY", "GameFontNormalSmall")
        vl:SetPoint("LEFT", ne, "RIGHT", 6, 0); vl:SetText("|cff888888Val:|r")
        local ve = CreateFrame("EditBox", nil, ef, "InputBoxTemplate")
        ve:SetSize(80, 18); ve:SetPoint("LEFT", vl, "RIGHT", 4, 0); ve:SetAutoFocus(false)
        self.edFields[i] = { nameBox = ne, valBox = ve }
    end

    local saveBtn = SmallBtn(ef, "Save", 60, function()
        local name = self.edName:GetText()
        local icon = self.edIconField:GetText()
        local cat = self.edCat:GetText()
        local text = self.edText:GetText()
        if not name or name == "" then return end
        local fields = {}
        for _, row in ipairs(self.edFields) do
            local n = strtrim(row.nameBox:GetText())
            local v = strtrim(row.valBox:GetText())
            if n ~= "" then fields[#fields + 1] = { name = n, value = v } end
        end
        if editingTemplateId then
            LXCG.Data:UpdateTemplate(editingTemplateId, name, icon, cat, text, fields)
        else
            LXCG.Data:CreateTemplate(name, icon, cat, text, fields)
        end
        ef:Hide()
    end); saveBtn:SetPoint("BOTTOMRIGHT", -12, 10)
    SmallBtn(ef, "Cancel", 60, function() ef:Hide() end):SetPoint("RIGHT", saveBtn, "LEFT", -8, 0)
end

function LXCG.Builder:ShowEditor(templateId)
    if not self.edFrame then return end
    editingTemplateId = templateId
    if templateId then
        local t = LXCG.Data:GetTemplate(templateId)
        if not t then return end
        self.edTitle:SetText("Edit Template")
        self.edName:SetText(t.name); self.edCat:SetText(t.category); self.edText:SetText(t.text)
        local short = t.icon; if type(short) == "string" then short = short:gsub("Interface\\Icons\\", "") else short = tostring(short) end
        self.edIconField:SetText(short); self.edIconPv:SetTexture(t.icon)
        local fields = t.fields or {}
        for i = 1, 3 do
            local f = fields[i]
            self.edFields[i].nameBox:SetText(f and f.name or "")
            self.edFields[i].valBox:SetText(f and f.value or "")
        end
    else
        self.edTitle:SetText("New Template")
        self.edName:SetText(""); self.edCat:SetText(""); self.edText:SetText("")
        self.edIconField:SetText(""); self.edIconPv:SetTexture(LXCG.CARD_BACK)
        for i = 1, 3 do self.edFields[i].nameBox:SetText(""); self.edFields[i].valBox:SetText("") end
    end
    self.edFrame:Show(); self.edName:SetFocus()
end

