        LXCG.Data:UpdateDeck(self._editingDeckId, name, icon ~= "" and icon or nil, desc)
        ef:Hide()
    end); saveBtn:SetPoint("BOTTOMRIGHT", -12, 10)
    SmallBtn(ef, "Cancel", 60, function() ef:Hide() end):SetPoint("RIGHT", saveBtn, "LEFT", -8, 0)
end

function LXCG.Builder:ShowDeckEditor(deckId)
    if not self.deckEdFrame then return end
    self._editingDeckId = deckId
    local deck = LXCG.Data.decks[deckId]
    if not deck then return end
    self.deNameBox:SetText(deck.name)
    self.deDescBox:SetText(deck.description or "")
    local iconStr = deck.icon or ""
    if type(iconStr) == "string" then iconStr = iconStr:gsub("Interface\\Icons\\", "") end
    self.deIconField:SetText(tostring(iconStr))
    self.deIconPv:SetTexture(deck.icon and LXCG:ResolveIcon(deck.icon) or LXCG.CARD_BACK)
    self.deckEdFrame:Show(); self.deNameBox:SetFocus()
end

function LXCG.Builder:CountDecks()
    local n = 0; for _ in pairs(LXCG.Data.decks) do n = n + 1 end; return n
end
